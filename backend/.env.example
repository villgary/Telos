# AccountScan Backend Environment Variables

# Master encryption key for AES-256-GCM credential encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ACCOUNTSCAN_MASTER_KEY=change_me_generate_with_python

# JWT secret key for authentication tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ACCOUNTSCAN_JWT_SECRET=change_me_generate_with_python

# JWT token expiration in minutes (default: 480 = 8 hours)
JWT_EXPIRE_MINUTES=480

# Database URL (default: SQLite for prototype)
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/accountscan
DATABASE_URL=sqlite:///./accountscan.db

# Server port (default: 8000)
PORT=8000
