# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (used by docker-compose and production)
# Default for local dev: SQLite (no DATABASE_URL needed — falls back to accountscan.db)
DATABASE_URL=postgresql://accountscan:changeme@db:5432/accountscan
DB_PASSWORD=changeme                       # PostgreSQL password — CHANGE THIS

# PostgreSQL connection pool (production)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_SSLMODE=prefer

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ACCOUNTSCAN_MASTER_KEY=<64-char-hex-key>  # AES-256 encryption key
ACCOUNTSCAN_JWT_SECRET=<64-char-hex-key>   # JWT signing key (must differ from MASTER_KEY)
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Redis (future: Celery broker) ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── SMTP (alerts) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Port on host for the frontend nginx container
FRONTEND_PORT=3000
